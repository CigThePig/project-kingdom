{
  "name": "project-kingdom",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "tsx scripts/audit/index.ts",
    "audit:inventory": "tsx scripts/audit/inventory.ts",
    "audit:seed": "tsx scripts/audit/index.ts --seed-artifacts",
    "audit:decrees": "tsx scripts/audit/index.ts --family=decree",
    "audit:crises": "tsx scripts/audit/index.ts --family=crisis",
    "audit:petitions": "tsx scripts/audit/index.ts --family=petition",
    "audit:assessments": "tsx scripts/audit/index.ts --family=assessment",
    "audit:negotiations": "tsx scripts/audit/index.ts --family=negotiation",
    "audit:overtures": "tsx scripts/audit/index.ts --family=overture",
    "audit:notifications": "tsx scripts/audit/index.ts --family=notification",
    "audit:hand": "tsx scripts/audit/index.ts --family=hand",
    "audit:reach": "tsx scripts/audit/index.ts --with-reach"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
